rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOwnerIdentity(data) {
      return data.ownerUid is string && data.ownerUid.size() > 0;
    }

    match /clients/{clientId} {
      allow create: if isSignedIn()
        && hasOwnerIdentity(request.resource.data)
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.id == clientId;

      allow read, update, delete: if isOwner(resource.data.ownerUid)
        && (
          request.method != 'update'
          || (
            hasOwnerIdentity(request.resource.data)
            && request.resource.data.ownerUid == resource.data.ownerUid
            && request.resource.data.id == resource.data.id
          )
        );
    }

    match /chantiers/{chantierId} {
      allow create: if isSignedIn()
        && hasOwnerIdentity(request.resource.data)
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.id == chantierId;

      allow read, update, delete: if isOwner(resource.data.ownerUid)
        && (
          request.method != 'update'
          || (
            hasOwnerIdentity(request.resource.data)
            && request.resource.data.ownerUid == resource.data.ownerUid
            && request.resource.data.id == resource.data.id
          )
        );
    }

    match /bills/{billId} {
      allow create: if isSignedIn()
        && hasOwnerIdentity(request.resource.data)
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.id == billId;

      allow read, update, delete: if isOwner(resource.data.ownerUid)
        && (
          request.method != 'update'
          || (
            hasOwnerIdentity(request.resource.data)
            && request.resource.data.ownerUid == resource.data.ownerUid
            && request.resource.data.id == resource.data.id
          )
        );
    }
  }
}
